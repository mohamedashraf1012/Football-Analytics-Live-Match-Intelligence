      "id": 1,
      "type": "stat",
      "title": "🏆 Live Score — ${home_club}",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "text": { "valueSize": 80 },
        "noValue": "0"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "none",
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"match_events\")\n  |> range(start: -2h)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"goals\")\n  |> filter(fn: (r) => r[\"club_name\"] == \"${home_club:raw}\")\n  |> filter(fn: (r) => r[\"_field\"] == \"player_name\")\n  |> count()",
          "refId": "A"
        }
      ]
    },
